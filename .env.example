# Copy to .env and fill in. .env is gitignored.

# TimescaleDB connection (SQLAlchemy / psycopg3 URL)
DATABASE_URL=postgresql+psycopg://garf:garf@localhost:5432/garf

# Garmin auth (handled by you — placeholder in client.py)
GC_EMAIL=
GC_PASSWD=

# Where garth stores OAuth tokens
GARF_TOKENSTORE=~/.garminconnect

# Daily sync re-pulls this many trailing days (idempotent upserts)
GARF_TRAILING_DAYS=3
